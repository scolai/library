@import url("/main.css");
@layer theme {
	:root {
		--dark: var(--n-200);
		--gray-darker: var(--n-300);
		--gray-dark: var(--n-400);
		--gray: var(--n-600);
		--gray-light: var(--n-700);
		--gray-lighter: var(--n-800);
		--light: var(--n-900);
		
		--heading: var(--font-sans);
		--text: var(--font-serif);
		--label-sans: var(--font-sans);
		
		--label-size: var(--label);
		--heading-size: var(--heading);
		--subheading-size: var(--subheading); 
	}
	
	
	body {
		background-color: var(--light); }
}
